---
const { img, title } = Astro.props;
---

<div class="flex items-start gap-4 p-4">
  <img src={img} alt={`${title} key`} width="56" height="56" class="h-14 w-14 shrink-0 rounded-md" />
  <div>
    <p class="font-semibold text-gray-900 dark:text-gray-100">{title}</p>
    <p class="mt-1 text-sm text-gray-600 dark:text-gray-400"><slot /></p>
  </div>
</div>
