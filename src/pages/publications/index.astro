---
import { getCollection } from "astro:content";

import BaseLayout from "@layouts/BaseLayout.astro";
import PageTitle from "@components/PageTitle.astro";
import HorizontalCard from "@components/HorizontalCard.astro";
import HomepageButton from "@components/HomepageButton.astro";
import FilterBar from "@components/FilterBar.astro";

import publications from "../../publications.json";
const pubs = (await getCollection("publications")).sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf(),
);

function short_authors(authors) {
  const num_authors = 10;
  if (authors.length > num_authors) {
    authors = authors.slice(0, num_authors - 1).concat({ family: "..." }, authors.slice(-1));
  }
  return authors
    .map((author) =>
      author.family ? author.family + " " + ((author.given ?? "") ? author.given.substr(0, 1) : "") : author.name,
    )
    .join(", ");
}

// Full author list (untruncated) for searching.
function all_authors(authors) {
  return authors
    .map((author) => (author.family ? `${author.family} ${author.given ?? ""}` : (author.name ?? "")))
    .join(" ");
}

// Preprints are identified by their hosting server rather than a peer-reviewed journal.
const PREPRINT_SERVERS = ["biorxiv", "medrxiv", "arxiv", "research square"];
const isPreprint = (journal: string) => PREPRINT_SERVERS.includes(journal.trim().toLowerCase());

const flagChips = [
  {
    key: "preprint",
    label: "Preprint",
    icon: "bi:file-earmark-text",
    count: pubs.filter((p) => isPreprint(p.data.journal)).length,
  },
];

// Group into [{ year, pubs }] preserving the descending-date sort.
const byYear: { year: number; pubs: typeof pubs }[] = [];
for (const post of pubs) {
  const year = publications[post.data.doi].published["date-parts"][0][0];
  let group = byYear.at(-1);
  if (!group || group.year !== year) {
    group = { year, pubs: [] };
    byYear.push(group);
  }
  group.pubs.push(post);
}
---

<BaseLayout title="Publications">
  <PageTitle>Publications</PageTitle>
  <p class="mb-3 text-xl">
    The cornerstone of the scientific method, peer reviewed journals are an important track record for any scientist.
  </p>
  <p class="mb-5 text-base font-light opacity-80">
    I've been lucky to work with some amazing people on some amazing projects. Here are some of the results.
  </p>
  <HomepageButton href="http://orcid.org/0000-0003-4101-2502" title="ORCiD" icon="simple-icons:orcid" />
  <HomepageButton
    href="https://scholar.google.se/citations?user=KJt8R0kAAAAJ&view_op=list_works&sortby=pubdate"
    title="Google Scholar"
    icon="simple-icons:googlescholar"
  />
  <HomepageButton
    href="http://www.researchgate.net/profile/Philip_Ewels"
    title="Research Gate"
    icon="simple-icons:researchgate"
  />

  <FilterBar noun="publication" placeholder="Search by title, journal or author…" flags={flagChips} />

  <div data-find-results>
    {
      byYear.map((group) => (
        <section data-find-group>
          <h2 class="mt-20 mb-4 text-2xl font-bold">{group.year}</h2>
          {group.pubs.map((post) => {
            const pub = publications[post.data.doi];
            return (
              <HorizontalCard
                title={post.data.title}
                subtitle={post.data.journal + " (" + pub.published["date-parts"][0][0] + ")"}
                description={short_authors(pub.author)}
                url={"/publications/" + post.id}
                doi={post.data.doi}
                badge={isPreprint(post.data.journal) ? "Preprint" : undefined}
                data-search={[post.data.title, post.data.journal, all_authors(pub.author)].filter(Boolean).join(" ")}
                data-preprint={String(isPreprint(post.data.journal))}
              />
            );
          })}
        </section>
      ))
    }
  </div>
</BaseLayout>
